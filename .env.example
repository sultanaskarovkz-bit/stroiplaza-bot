# .env.example - скопируй в .env и заполни

# WhatsApp provider: "meta" или "green"
WA_PROVIDER=meta

# Meta WhatsApp Cloud API
META_TOKEN=your_meta_access_token
META_PHONE_ID=your_phone_number_id
META_VERIFY_TOKEN=stroiplaza_verify_2024

# Green API (если WA_PROVIDER=green)
GREEN_ID=your_instance_id
GREEN_TOKEN=your_api_token

# Claude AI
ANTHROPIC_API_KEY=your_claude_api_key

# Server
PORT=3000
